PORT=3001
LOG_LEVEL=debug
LOG_PRETTY=true

# Path to GCP service account JSON (Vision API enabled on the project).
# export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json
GOOGLE_APPLICATION_CREDENTIALS=

# Set to true to always OCR with Vision (ignore embedded PDF text).
PDF_USE_VISION_ONLY=false

# OpenAI-compatible API config for netsheet extraction
# If OPENROUTER_API_KEY is set, requests go to OPENROUTER_BASE_URL (OPENAI_BASE_URL is ignored).
# Use only OPENAI_API_KEY for direct OpenAI (sk-...), not OpenRouter keys (sk-or-v1-...).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free models are often upstream rate-limited; use a paid model or add provider keys in OpenRouter → Integrations.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# Recommended by OpenRouter for attribution/rate-limits
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=real-estate-netsheet

# Direct OpenAI (only when OPENROUTER_API_KEY is empty)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin (server)
# Option A: paste service account JSON (stringified) for local dev.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: provide individual fields (recommended for Render env vars)
FIREBASE_PROJECT_ID=net-sheets-f85bb
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@net-sheets-f85bb.iam.gserviceaccount.com
# Keep literal \n sequences in the value (we'll convert them at runtime)
